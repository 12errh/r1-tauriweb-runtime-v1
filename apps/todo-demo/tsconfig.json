{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@tauri-apps/api": ["../../node_modules/@tauri-apps/api"],
      "@tauri-apps/api/*": ["../../node_modules/@tauri-apps/api/*"]
    }
  },
  "include": ["src"]
}
