{
  "name": "@r1-runtime/vite-plugin",
  "version": "0.3.1",
  "description": "Official Vite plugin for R1 — automates Rust→WASM compilation and Tauri import patching.",
  "type": "module",
  "author": "R1 Runtime Team",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "tauri",
    "wasm",
    "webassembly",
    "browser",
    "runtime",
    "r1",
    "vite",
    "vite-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/12errh/r1-tauriweb-runtime-v1"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "esbuild": "^0.20.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  }
}
