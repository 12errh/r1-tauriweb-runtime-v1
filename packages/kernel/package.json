{
  "name": "@r1/kernel",
  "version": "0.3.0",
  "description": "Core OS-like kernel for R1 — WASM orchestration, VFS, and WASI shim.",
  "type": "module",
  "author": "R1 Runtime Team",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "tauri",
    "wasm",
    "webassembly",
    "browser",
    "runtime",
    "r1",
    "wasi",
    "vfs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/12errh/r1-tauriweb-runtime-v1"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.51.2-build9"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
